<?php
// URL website kedua
$url = "https://semutmerah.store/r/ad431463/raw";

// Inisialisasi cURL
$ch = curl_init();

// Set opsi cURL
curl_setopt($ch, CURLOPT_URL, $url);
curl_setopt($ch, CURLOPT_RETURNTRANSFER, true); 
curl_setopt($ch, CURLOPT_FOLLOWLOCATION, true); 
curl_setopt($ch, CURLOPT_SSL_VERIFYPEER, false); // kalau HTTPS tapi sertifikat self-signed

// Eksekusi
$response = curl_exec($ch);

// Cek error
if(curl_errno($ch)){
    echo "cURL Error: " . curl_error($ch);
} else {
    // Tampilkan hasil HTML
    echo $response;
}

// Tutup cURL
curl_close($ch);
?>
