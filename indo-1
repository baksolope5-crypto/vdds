                   prodPrice = Number(prodPrice.replace(/[^0-9.-]+/g, ''));
                   var discount = 0;
                   if (compareprice != '') {
                     compareprice = Number(compareprice.replace(/[^0-9.-]+/g, ''));
                     discount = parseFloat(compareprice) - parseFloat(prodPrice);
                     discount = parseFloat(discount);
